#!/bin/bash
set -euo pipefail

# ─────────────────────────────────────────────────────────────────
# sync_from_robeast — pull directories FROM robeast TO this machine
#
# Direction:  robeast  ───>  here
# Safety:     --update means newer local files are NEVER overwritten
# Default:    DRY RUN (shows what would happen, changes nothing)
# Usage:      sync_from_robeast [path...] [--go] [--force]
#   sync_from_robeast                         — dry run all (~/w, ~/kod, ~/ow)
#   sync_from_robeast ~/w ~/kod               — dry run w and kod only
#   sync_from_robeast ~/w/pesto --go          — live sync, preserve newer local
#   sync_from_robeast ~/w/pesto --go --force  — live sync, source wins (clobber)
# ─────────────────────────────────────────────────────────────────

REMOTE="robeast"
ALL_DIRS=(w kod ow)
EXCLUSIONS="$HOME/scripts/dev.exclusions"

if [[ ! -f "$EXCLUSIONS" ]]; then
  echo "ERROR: exclusions file not found: $EXCLUSIONS"
  exit 1
fi

# Normalize a path to be relative to $HOME
normalize() {
  local p="$1"
  p="${p/#\~\//$HOME/}"   # expand ~/
  p="${p/#$HOME\//}"      # strip $HOME/
  p="${p%/}"              # strip trailing slash
  echo "$p"
}

# Parse arguments
DRY_RUN="--dry-run"
FORCE=""
DIRS=()
for arg in "$@"; do
  if [[ "$arg" == "--go" ]]; then
    DRY_RUN=""
  elif [[ "$arg" == "--force" ]]; then
    FORCE="1"
  else
    DIRS+=("$(normalize "$arg")")
  fi
done
[[ ${#DIRS[@]} -eq 0 ]] && DIRS=("${ALL_DIRS[@]}")

UPDATE_FLAG="--update"
[[ -n "$FORCE" ]] && UPDATE_FLAG=""

if [[ -z "$DRY_RUN" ]]; then
  if [[ -n "$FORCE" ]]; then
    echo "╔══════════════════════════════════════════════════════════╗"
    echo "║  LIVE SYNC (FORCE): robeast ──> here                   ║"
    echo "║  Dirs: $(printf '%s ' "${DIRS[@]}")"
    echo "║  SOURCE WINS — local files WILL be overwritten         ║"
    echo "╚══════════════════════════════════════════════════════════╝"
  else
    echo "╔══════════════════════════════════════════════════════════╗"
    echo "║  LIVE SYNC: robeast ──> here                           ║"
    echo "║  Dirs: $(printf '%s ' "${DIRS[@]}")"
    echo "║  Newer local files will NOT be overwritten (--update)   ║"
    echo "╚══════════════════════════════════════════════════════════╝"
  fi
  echo
  read -rp "Proceed? [y/N] " confirm
  if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
    echo "Aborted."
    exit 0
  fi
else
  echo "╔══════════════════════════════════════════════════════════╗"
  echo "║  DRY RUN: robeast ──> here $([ -n "$FORCE" ] && echo "(FORCE)" || echo "       ")"
  echo "║  Dirs: $(printf '%s ' "${DIRS[@]}")"
  echo "║  Nothing will be changed. Use --go to execute.          ║"
  echo "╚══════════════════════════════════════════════════════════╝"
  echo
fi

for dir in "${DIRS[@]}"; do
  echo "── syncing ~/$dir/ ──"
  mkdir -p "$HOME/$dir/"
  rsync -az --out-format='%n' --stats $UPDATE_FLAG \
    --exclude-from="$EXCLUSIONS" \
    $DRY_RUN \
    "${REMOTE}:~/${dir}/" "$HOME/$dir/"
  echo
done

if [[ -n "$DRY_RUN" ]]; then
  echo "Dry run complete. To apply, run: sync_from_robeast ${DIRS[*]} --go$([ -n "$FORCE" ] && echo " --force")"
else
  echo "Sync complete: robeast ──> here (${DIRS[*]})"
fi
