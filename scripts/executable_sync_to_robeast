#!/bin/bash
set -euo pipefail

# ─────────────────────────────────────────────────────────────────
# sync_to_robeast — push directories FROM this machine TO robeast
#
# Direction:  here  ───>  robeast
# Safety:     --update means newer remote files are NEVER overwritten
# Default:    DRY RUN (shows what would happen, changes nothing)
# Usage:      sync_to_robeast [path...] [--go] [--force]
#   sync_to_robeast                         — dry run all (~/w, ~/kod, ~/ow)
#   sync_to_robeast ~/w ~/kod               — dry run w and kod only
#   sync_to_robeast ~/w/myproject --go          — live sync, preserve newer remote
#   sync_to_robeast ~/w/myproject --go --force  — live sync, source wins (clobber)
# ─────────────────────────────────────────────────────────────────

REMOTE="robeast"
ALL_DIRS=(w kod ow)
EXCLUSIONS="$HOME/scripts/dev.exclusions"

if [[ ! -f "$EXCLUSIONS" ]]; then
	echo "ERROR: exclusions file not found: $EXCLUSIONS"
	exit 1
fi

# Normalize a path to be relative to $HOME
normalize() {
	local p="$1"
	p="${p/#\~\//$HOME/}" # expand ~/
	p="${p/#$HOME\//}"    # strip $HOME/
	p="${p%/}"            # strip trailing slash
	echo "$p"
}

# Parse arguments
DRY_RUN="--dry-run"
FORCE=""
DIRS=()
for arg in "$@"; do
	if [[ "$arg" == "--go" ]]; then
		DRY_RUN=""
	elif [[ "$arg" == "--force" ]]; then
		FORCE="1"
	else
		DIRS+=("$(normalize "$arg")")
	fi
done
[[ ${#DIRS[@]} -eq 0 ]] && DIRS=("${ALL_DIRS[@]}")

UPDATE_FLAG="--update"
DELETE_FLAG=""
if [[ -n "$FORCE" ]]; then
	UPDATE_FLAG=""
	DELETE_FLAG="--delete"
fi

# Verify source dirs exist
for dir in "${DIRS[@]}"; do
	if [[ ! -d "$HOME/$dir" ]]; then
		echo "ERROR: source directory not found: ~/$dir"
		echo "Nothing to push. Run sync_from_robeast first?"
		exit 1
	fi
done

if [[ -z "$DRY_RUN" ]]; then
	if [[ -n "$FORCE" ]]; then
		echo "╔══════════════════════════════════════════════════════════╗"
		echo "║  LIVE SYNC (FORCE): here ──> robeast                   ║"
		echo "║  Dirs: $(printf '%s ' "${DIRS[@]}")"
		echo "║  SOURCE WINS — remote files WILL be overwritten        ║"
		echo "╚══════════════════════════════════════════════════════════╝"
	else
		echo "╔══════════════════════════════════════════════════════════╗"
		echo "║  LIVE SYNC: here ──> robeast                           ║"
		echo "║  Dirs: $(printf '%s ' "${DIRS[@]}")"
		echo "║  Newer remote files will NOT be overwritten (--update)  ║"
		echo "╚══════════════════════════════════════════════════════════╝"
	fi
	echo
	read -rp "Proceed? [y/N] " confirm
	if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
		echo "Aborted."
		exit 0
	fi
else
	echo "╔══════════════════════════════════════════════════════════╗"
	echo "║  DRY RUN: here ──> robeast $([ -n "$FORCE" ] && echo "(FORCE)" || echo "       ")"
	echo "║  Dirs: $(printf '%s ' "${DIRS[@]}")"
	echo "║  Nothing will be changed. Use --go to execute.          ║"
	echo "╚══════════════════════════════════════════════════════════╝"
	echo
fi

for dir in "${DIRS[@]}"; do
	echo "── syncing ~/$dir/ ──"

	# rsync --delete refuses to remove dirs that still contain excluded
	# content (e.g. a dest-only project with _build/ or .DS_Store inside).
	# Under --force, pre-purge those via rm -rf so the sync becomes a mirror.
	if [[ -n "$FORCE" ]]; then
		mapfile -t stale < <(
			rsync -an --delete --exclude-from="$EXCLUSIONS" \
				"$HOME/$dir/" "${REMOTE}:~/${dir}/" 2>&1 |
				sed -n 's|^rsync([0-9]*): warning: .*//\./\(.*\): not empty, cannot delete$|\1|p' || true
		)
		if [[ ${#stale[@]} -gt 0 ]]; then
			if [[ -n "$DRY_RUN" ]]; then
				echo "  would pre-purge ${#stale[@]} stale dir(s) on ${REMOTE}:"
			else
				echo "  pre-purging ${#stale[@]} stale dir(s) on ${REMOTE}:"
			fi
			printf '    %s\n' "${stale[@]}"
			if [[ -z "$DRY_RUN" ]]; then
				printf '%s\0' "${stale[@]}" |
					ssh "$REMOTE" "cd ~/$dir && xargs -0 rm -rf --"
			fi
		fi
	fi

	rsync -az --out-format='%n' --stats $UPDATE_FLAG $DELETE_FLAG \
		--exclude-from="$EXCLUSIONS" \
		$DRY_RUN \
		"$HOME/$dir/" "${REMOTE}:~/${dir}/"
	echo
done

if [[ -n "$DRY_RUN" ]]; then
	echo "Dry run complete. To apply, run: sync_to_robeast ${DIRS[*]} --go$([ -n "$FORCE" ] && echo " --force")"
else
	echo "Sync complete: here ──> robeast (${DIRS[*]})"
fi
