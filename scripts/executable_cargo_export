#!/bin/bash
#
# cargo_export - Export cargo-installed crates and sync to chezmoi repo
#
# Exports installed crates to crates.conf, adds to chezmoi, commits, and pushes.
# Format: one crate name per line (without version, to always get latest on converge)

set -euo pipefail

CONFIG_FILE="${HOME}/.config/cargo-crates/crates.conf"
CONFIG_DIR="$(dirname "$CONFIG_FILE")"

mkdir -p "$CONFIG_DIR"

echo "=== cargo_export ==="
echo "Exporting installed crates to: $CONFIG_FILE"
echo ""

cargo install --list | awk '/^[a-zA-Z]/ {gsub(/ .*/, ""); print}' | sort > "$CONFIG_FILE"

count=$(wc -l < "$CONFIG_FILE" | tr -d ' ')
echo "Done. $count crates exported."
echo ""

chezmoi add "$CONFIG_FILE"
chezmoi git -- add private_dot_config/cargo-crates/crates.conf

if chezmoi git -- diff --quiet --staged; then
    echo "No changes to commit."
else
    chezmoi git -- commit -m "update crates.conf ($count cargo crates)"
    chezmoi git -- push
    echo "Committed and pushed."
fi
