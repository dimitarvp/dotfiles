#!/usr/bin/env bash
set -euo pipefail

# Print the name of the default branch (main, master, etc.)
# 1. Try the remote HEAD symbolic ref (most reliable, set by `git remote set-head origin --auto`)
# 2. Fall back to checking common branch names against the remote
# 3. Last resort: check local branches

remote=${1:-origin}

if ref=$(git symbolic-ref "refs/remotes/$remote/HEAD" 2>/dev/null); then
    echo "${ref#refs/remotes/$remote/}"
    exit 0
fi

for candidate in main master; do
    if git rev-parse --verify "refs/remotes/$remote/$candidate" &>/dev/null; then
        echo "$candidate"
        exit 0
    fi
done

for candidate in main master; do
    if git rev-parse --verify "refs/heads/$candidate" &>/dev/null; then
        echo "$candidate"
        exit 0
    fi
done

echo "error: cannot determine default branch" >&2
exit 1
