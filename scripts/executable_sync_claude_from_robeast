#!/bin/bash
set -euo pipefail

# ─────────────────────────────────────────────────────────────────
# sync_claude_from_robeast — pull ~/.claude FROM robeast TO here
#
# Direction:  robeast  ───>  here
# Safety:     SOURCE WINS — local files are overwritten
# ─────────────────────────────────────────────────────────────────

REMOTE="robeast"
DIR=".claude"

echo "syncing robeast:~/.claude ──> ~/.claude"
mkdir -p "$HOME/$DIR/"
rsync -avz --progress --delete \
  "${REMOTE}:~/${DIR}/" "$HOME/$DIR/"
echo "done."
