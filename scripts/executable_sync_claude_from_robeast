#!/bin/bash
set -euo pipefail

# ─────────────────────────────────────────────────────────────────
# sync_claude_from_robeast — pull ~/.claude FROM robeast TO here
#
# Direction:  robeast  ───>  here
# Safety:     SOURCE WINS — local files are overwritten
# Default:    DRY RUN (shows what would happen, changes nothing)
# Usage:      sync_claude_from_robeast [--go]
# ─────────────────────────────────────────────────────────────────

REMOTE="robeast"
DIR=".claude"

DRY_RUN="--dry-run"
if [[ "${1:-}" == "--go" ]]; then
  DRY_RUN=""
fi

if [[ -z "$DRY_RUN" ]]; then
  echo "╔══════════════════════════════════════════════════════════╗"
  echo "║  LIVE SYNC: robeast:~/.claude ──> ~/.claude             ║"
  echo "║  WARNING: local files WILL be overwritten               ║"
  echo "╚══════════════════════════════════════════════════════════╝"
  echo
  read -rp "Proceed? [y/N] " confirm
  if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
    echo "Aborted."
    exit 0
  fi
else
  echo "╔══════════════════════════════════════════════════════════╗"
  echo "║  DRY RUN: robeast:~/.claude ──> ~/.claude               ║"
  echo "║  Nothing will be changed. Use --go to execute.          ║"
  echo "╚══════════════════════════════════════════════════════════╝"
  echo
fi

mkdir -p "$HOME/$DIR/"
rsync -avz --progress --delete \
  $DRY_RUN \
  "${REMOTE}:~/${DIR}/" "$HOME/$DIR/"

if [[ -n "$DRY_RUN" ]]; then
  echo
  echo "Dry run complete. To apply, run: sync_claude_from_robeast --go"
else
  echo
  echo "Sync complete: robeast:~/.claude ──> ~/.claude"
fi
