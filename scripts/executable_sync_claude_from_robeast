#!/bin/bash
set -euo pipefail

# ─────────────────────────────────────────────────────────────────
# sync_claude_from_robeast — pull all Claude data FROM robeast
#
# Direction:  robeast  ───>  here
# Safety:     SOURCE WINS — local files are overwritten
#
# Syncs: ~/.claude/       (memories, projects, plugins, skills, settings, history)
#        ~/.claude-code/  (Claude Code app settings)
#        ~/.claude.json   (auth token)
# ─────────────────────────────────────────────────────────────────

REMOTE="robeast"

echo "syncing Claude data from robeast..."

mkdir -p "$HOME/.claude/" "$HOME/.claude-code/"

rsync -az --out-format='%n' --stats --delete \
  "${REMOTE}:~/.claude/" "$HOME/.claude/"

rsync -az --out-format='%n' --stats --delete \
  "${REMOTE}:~/.claude-code/" "$HOME/.claude-code/"

rsync -az --out-format='%n' --stats \
  "${REMOTE}:~/.claude.json" "$HOME/.claude.json"

echo "done."
