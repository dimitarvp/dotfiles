#!/bin/bash
#
# gup_export - Export gup tools to the chezmoi-managed config
#
# Always writes to ~/.config/gup/gup.conf (the chezmoi source of truth)
# instead of the platform-specific default location.

set -euo pipefail

CONFIG_FILE="${HOME}/.config/gup/gup.conf"
CONFIG_DIR="$(dirname "$CONFIG_FILE")"

# Ensure directory exists
mkdir -p "$CONFIG_DIR"

echo "Exporting installed tools to: $CONFIG_FILE"
gup export -o > "$CONFIG_FILE"

echo "Done. $(wc -l < "$CONFIG_FILE" | tr -d ' ') tools exported."
echo ""
echo "Don't forget to commit this in chezmoi if you want to sync across machines."
