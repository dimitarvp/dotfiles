#!/bin/bash
#
# gup_export - Export gup tools and sync to chezmoi repo
#
# Exports installed Go tools to gup.json, adds to chezmoi, commits, and pushes.

set -euo pipefail

CONFIG_FILE="${HOME}/.config/gup/gup.json"

echo "=== gup_export ==="
echo "Exporting installed tools to: $CONFIG_FILE"

gup export -f "$CONFIG_FILE"

count=$(grep -c '"name"' "$CONFIG_FILE")
echo "Done. $count tools exported."
echo ""

chezmoi add "$CONFIG_FILE"
chezmoi git -- add private_dot_config/gup/private_gup.json

if chezmoi git -- diff --quiet --staged; then
	echo "No changes to commit."
else
	chezmoi git -- commit -m "update gup.json ($count go tools)"
	chezmoi git -- push
	echo "Committed and pushed."
fi
