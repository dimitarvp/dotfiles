#!/bin/bash
set -euo pipefail

# ─────────────────────────────────────────────────────────────────
# sync_claude_to_robeast — push ~/.claude FROM here TO robeast
#
# Direction:  here  ───>  robeast
# Safety:     SOURCE WINS — remote files are overwritten
# ─────────────────────────────────────────────────────────────────

REMOTE="robeast"
DIR=".claude"

if [[ ! -d "$HOME/$DIR" ]]; then
  echo "ERROR: ~/.claude not found. Nothing to push."
  exit 1
fi

echo "syncing ~/.claude ──> robeast:~/.claude"
rsync -avz --progress --delete \
  "$HOME/$DIR/" "${REMOTE}:~/${DIR}/"
echo "done."
