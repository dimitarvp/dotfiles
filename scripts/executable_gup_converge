#!/bin/zsh
#
# gup_converge - Converge gup-managed Go tools to match the config
#
# 1. Install only missing tools (compare gup list vs gup.json)
# 2. Update all installed tools to latest
# 3. Prune tools not in config
# 4. (removed: auto-export was dangerous — use gup_export manually)
#
# The source of truth is always ~/.config/gup/gup.json (managed by chezmoi)

set -euo pipefail

eval "$(mise activate zsh --shims)"
export GOBIN="$HOME/go/bin"

CONFIG_FILE="${HOME}/.config/gup/gup.json"

if [[ ! -f "$CONFIG_FILE" ]]; then
    echo "ERROR: Config file not found: $CONFIG_FILE"
    echo "Run 'chezmoi apply' first to create it."
    exit 1
fi

echo "=== gup_converge ==="
echo "Config: $CONFIG_FILE"
echo ""

# Get sorted list of installed tool names
installed=$(gup list 2>/dev/null | awk -F: '{gsub(/^[ \t]+|[ \t]+$/, "", $1); print $1}' | sort)

# Get sorted list of tool names from config
configured=$(jq -r '.packages[].name' "$CONFIG_FILE" | sort)

# 1. Install only missing tools
echo ">>> Phase 1: Installing missing tools..."
to_install=$(comm -23 <(echo "$configured") <(echo "$installed"))

if [[ -z "$to_install" ]]; then
    echo "Nothing to install. All configured tools are present."
else
    while IFS= read -r name; do
        # Look up import_path from the JSON
        import_path=$(jq -r --arg n "$name" '.packages[] | select(.name == $n) | .import_path' "$CONFIG_FILE")
        echo "[INSTALL] $name ($import_path@latest)"
        go install "${import_path}@latest"
    done <<< "$to_install"
fi
echo ""

# 2. Update all installed tools to latest
echo ">>> Phase 2: Updating all tools to latest..."
gup update
echo ""

# 3. Prune: remove tools not in config
echo ">>> Phase 3: Checking for tools to prune..."

# Re-fetch installed list after installs/updates
installed=$(gup list 2>/dev/null | awk -F: '{gsub(/^[ \t]+|[ \t]+$/, "", $1); print $1}' | sort)
to_prune=$(comm -23 <(echo "$installed") <(echo "$configured"))

if [[ -z "$to_prune" ]]; then
    echo "Nothing to prune."
else
    echo "Pruning:"
    echo "$to_prune"
    echo ""
    echo "$to_prune" | xargs gup remove -f
fi
echo ""

# NOTE: do NOT auto-export here. If gup update fails, the config would be
# overwritten with only surviving tools. Run gup_export manually instead.
echo "Done. Run gup_export manually if you added new tools."
