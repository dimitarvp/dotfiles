# =============================================================================
# chezmoi ignore file
# =============================================================================
# This file specifies patterns to exclude from chezmoi management.
# Uses Go text/template syntax for conditionals.
#
# Available variables:
#   .chezmoi.os          - "darwin", "linux", "windows"
#   .chezmoi.arch        - "amd64", "arm64"
#   .chezmoi.hostname    - machine hostname
#   .chezmoi.username    - current user
#   .chezmoi.homeDir     - user's home directory
#   .chezmoi.sourceDir   - chezmoi source directory
#
# Pattern syntax:
#   *        - matches any sequence of non-separator characters
#   **       - matches any sequence of characters including separators
#   ?        - matches any single non-separator character
#   [class]  - matches any character in the class
#
# Negation: prefix with ! to re-include a previously excluded pattern
# =============================================================================

# -----------------------------------------------------------------------------
# Always ignored (all systems)
# -----------------------------------------------------------------------------
README.md
CLAUDE_WIP_tidy_config.md

# -----------------------------------------------------------------------------
# macOS-only files (ignore on non-Darwin systems)
# -----------------------------------------------------------------------------
{{- if ne .chezmoi.os "darwin" }}
# Add macOS-specific files here, e.g.:
# dot_zsh/macos_specific.zsh
# private_dot_config/some_macos_app/
{{- end }}

# -----------------------------------------------------------------------------
# Linux-only files (ignore on non-Linux systems)
# -----------------------------------------------------------------------------
{{- if ne .chezmoi.os "linux" }}
# Add Linux-specific files here, e.g.:
# dot_zsh/linux_specific.zsh
# private_dot_config/some_linux_app/
{{- end }}

# -----------------------------------------------------------------------------
# Hostname: s1 (Home server)
# -----------------------------------------------------------------------------
{{- if eq .chezmoi.hostname "s1" }}
# Add files to ignore on home server, e.g.:
# private_dot_config/alacritty/  # no GUI
# private_dot_config/ghostty/    # no GUI
{{- end }}

