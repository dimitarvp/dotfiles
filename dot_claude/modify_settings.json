#!/bin/sh
# Ensure statusLine + transcript retention are configured in
# ~/.claude/settings.json; pass all other keys through untouched
# (Claude Code rewrites this file itself).
input=$(cat)
[ -z "$input" ] && input='{}'
current=$(printf '%s\n' "$input" | jq -r '[(.statusLine.command // ""), (.cleanupPeriodDays // "" | tostring)] | join("|")')
if [ "$current" = '~/.claude/statusline.sh|1825' ]; then
	printf '%s\n' "$input"
else
	printf '%s\n' "$input" | jq '.statusLine = {"type": "command", "command": "~/.claude/statusline.sh"} | .cleanupPeriodDays = 1825'
fi
