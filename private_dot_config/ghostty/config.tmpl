# Font configuration
font-family = UbuntuMono Nerd Font Mono
font-style = Regular
font-style-bold = Bold
font-style-italic = Italic
font-style-bold-italic = Bold Italic
font-size = {{ .font_size }}

# Window configuration
macos-titlebar-style = tabs
window-save-state = always
macos-window-shadow = false
window-width = 9999
window-height = 9999
quit-after-last-window-closed = true

# Colors - Primary
background = 0f0f0f
foreground = f8f8f2

# Cursor
cursor-color = eceff4
cursor-text = 282828
cursor-style = block
cursor-style-blink = false
shell-integration-features = no-cursor,ssh-terminfo,ssh-env

# Selection
selection-background = f8f8f2
selection-foreground = 545454

# Normal colors (palette 0-7)
palette = 0=#21222c
palette = 1=#ff5555
palette = 2=#50fa7b
palette = 3=#ffcb6b
palette = 4=#82aaff
palette = 5=#c792ea
palette = 6=#8be9fd
palette = 7=#f8f8f2

# Bright colors (palette 8-15)
palette = 8=#545454
palette = 9=#ff6e6e
palette = 10=#69ff94
palette = 11=#ffcb6b
palette = 12=#d6acff
palette = 13=#ff92df
palette = 14=#a4ffff
palette = 15=#f8f8f2

# Scrollback
scrollback-limit = 100000

# Copy on select
copy-on-select = clipboard

# Make Option key work as Alt (covers all your Alt+letter bindings)
macos-option-as-alt = true

# Key bindings
keybind = super+n=new_window
keybind = ctrl+space=text:\x00
